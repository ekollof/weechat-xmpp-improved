# Maintainer: Emiel Kollof <emiel@kollof.nl>
pkgname=weechat-xmpp
pkgver=0.2.0
pkgrel=1
pkgdesc="WeeChat plugin for XMPP/Jabber protocol"
arch=('x86_64' 'aarch64')
url="https://git.hackerheaven.org/ekollof/weechat-xmpp-improved"
license=('MPL2')
depends=(
    'weechat'
    'libstrophe'
    'libxml2'
    'lmdb'
    'libsignal-protocol-c'
    'gpgme'
    'fmt'
    'curl'
    'openssl'
)
makedepends=(
    'gcc>=12'
    'git'
    'bison'
    'flex'
)
source=("git+https://git.hackerheaven.org/ekollof/weechat-xmpp-improved.git#tag=v${pkgver}")
sha256sums=('SKIP')

prepare() {
    cd "$srcdir/weechat-xmpp-improved"
    git submodule update --init --recursive
}

build() {
    cd "$srcdir/weechat-xmpp-improved"
    make weechat-xmpp
}

package() {
    cd "$srcdir/weechat-xmpp-improved"
    install -Dm755 xmpp.so "$pkgdir/usr/lib/weechat/plugins/xmpp.so"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
